# ============================================
# LLM Provider Configuration
# ============================================

# Choose your LLM provider: openai, minimax, or mock
# - openai: Use OpenAI API (gpt-4o, gpt-4o-mini)
# - minimax: Use Minimax API (abab6.5s-chat) - Cheaper!
# - mock: Use mock data for testing (free)
LLM_PROVIDER=minimax

# ============================================
# OpenAI Configuration
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI models to use
JUDGE_MODEL_1=gpt-4o
JUDGE_MODEL_2=gpt-4o-mini

# ============================================
# Minimax Configuration (Recommended - 10x cheaper!)
# ============================================
# Get your credentials from: https://platform.minimaxi.com/
# 1. Sign up at https://platform.minimaxi.com/
# 2. Go to API Keys section
# 3. Create new API key
# 4. Copy API Key and Group ID

MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# ============================================
# Runtime Configuration
# ============================================
# Set to "true" to use mock runtime (for testing without API costs)
USE_MOCK_RUNTIME=false

# ============================================
# Cost Comparison (100 samples)
# ============================================
# OpenAI:  ~$1-2
# Minimax: ~$0.10 (90% cheaper!)
# Mock:    Free

# ============================================
# Quick Start
# ============================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Choose provider and add credentials:
#    - For Minimax: Set MINIMAX_API_KEY and MINIMAX_GROUP_ID
#    - For OpenAI: Set OPENAI_API_KEY
#
# 3. Test:
#    python test_minimax.py  (for Minimax)
#    python test_real_api.py (for OpenAI)
#
# 4. Run benchmark:
#    python run_benchmark.py --dataset data/hotpot_100.json
